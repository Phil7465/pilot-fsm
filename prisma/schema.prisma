generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DRIVER
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
}

enum VatCode {
  STANDARD
  REDUCED
  ZERO
  EXEMPT
}

enum PaymentMethod {
  CARD
  DIRECT_DEBIT
  CASH
  BANK_TRANSFER
}

enum RecurrenceInterval {
  MONTHLY
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  role           Role     @default(DRIVER)
  passwordHash   String
  customers      Customer[] @relation("AccountCustomers")
  jobsAssigned   Job[]      @relation("JobAssigned")
  jobsCreated    Job[]      @relation("JobCreated")
  createdInvoices Invoice[] @relation("InvoiceCreatedBy")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  accounts       Account[]
  sessions       Session[]
  errorLogs      ErrorLog[]
}

model ErrorLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level      String   @default("error")
  message    String
  stack      String?
  url        String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  company     String?
  phone       String?
  email       String?
  addressLine String
  city        String
  postcode    String
  country     String   @default("GB")
  vatStatus   VatCode  @default(STANDARD)
  // Shipping address (separate from billing)
  shipAddressLine String?
  shipCity        String?
  shipPostcode    String?
  shipCountry     String?
  // QuickBooks fields (QBO is source of truth)
  qbCustomerId    String?  @unique
  qbSyncToken     String?
  qbActive        Boolean  @default(true)
  createdById String
  createdBy   User     @relation("AccountCustomers", fields: [createdById], references: [id])
  jobs        Job[]
  invoices    Invoice[]
  recurringInvoices RecurringInvoice[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([company])
}

model ServiceTemplate {
  id             String  @id @default(cuid())
  name           String
  description    String?
  unitPrice      Decimal @db.Decimal(10, 2)
  vatCode        VatCode @default(STANDARD)
  incomeAccount  String
  isRecurring    Boolean @default(false)
  // QuickBooks fields (QBO is source of truth for items)
  qbItemId       String? @unique
  qbSyncToken    String?
  qbItemType     String? // Service, NonInventory, Inventory
  qbActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobLineItems   JobLineItem[]
  invoiceLineItems InvoiceLineItem[]
  recurringLineItems RecurringLineItem[]
}

model Job {
  id             String    @id @default(cuid())
  reference      String    @unique
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  deliveryAddress String
  invoiceAddress String?
  serviceDate    DateTime
  assignedStaffId String?
  assignedStaff  User?     @relation("JobAssigned", fields: [assignedStaffId], references: [id])
  createdById    String
  createdBy      User      @relation("JobCreated", fields: [createdById], references: [id])
  status         JobStatus @default(SCHEDULED)
  notes          String?
  lineItems      JobLineItem[]
  invoices       Invoice[]
  attachments    Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model JobLineItem {
  id                String   @id @default(cuid())
  jobId             String
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  serviceTemplateId String?
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
  description       String
  quantity          Decimal @db.Decimal(8, 2)
  unitPrice         Decimal @db.Decimal(10, 2)
  vatCode           VatCode
  incomeAccount     String
  createdAt         DateTime @default(now())
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  jobId          String?
  job            Job?          @relation(fields: [jobId], references: [id])
  issueDate      DateTime
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(12, 2)
  vatTotal       Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  balanceDue     Decimal       @db.Decimal(12, 2)
  currency       String        @default("GBP")
  notes          String?
  // QuickBooks fields (QBO is source of truth for invoices)
  qbInvoiceId    String?       @unique
  qbSyncToken    String?
  qbPrivateNote  String?       // App can write PrivateNote → QBO
  createdById    String
  createdBy      User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  lineItems      InvoiceLineItem[]
  payments       Payment[]
  recurringParentId String?
  recurringParent   RecurringInvoice? @relation(fields: [recurringParentId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([issueDate])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLineItem {
  id                String   @id @default(cuid())
  invoiceId         String
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
  serviceTemplateId String?
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
  description       String
  quantity          Decimal @db.Decimal(8, 2)
  unitPrice         Decimal @db.Decimal(10, 2)
  vatCode           VatCode
  incomeAccount     String
  total             Decimal @db.Decimal(12, 2)
  // QuickBooks line item ID
  qbLineId          String?
}

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  amount       Decimal       @db.Decimal(12, 2)
  paymentDate  DateTime
  method       PaymentMethod
  reference    String?
  provider     String?
  providerPaymentId String?
  // QuickBooks fields (QBO is source of truth for payments)
  qbPaymentId  String?       @unique
  qbSyncToken  String?
  createdAt    DateTime @default(now())

  @@index([paymentDate])
}

model RecurringInvoice {
  id             String   @id @default(cuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id])
  startDate      DateTime
  nextRunDate    DateTime
  interval       RecurrenceInterval @default(MONTHLY)
  active         Boolean  @default(true)
  lineItems      RecurringLineItem[]
  timezone       String   @default("Europe/London")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoices       Invoice[]
}

model RecurringLineItem {
  id                String   @id @default(cuid())
  recurringInvoiceId String
  recurringInvoice  RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id])
  serviceTemplateId String?
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
  description       String
  quantity          Decimal @db.Decimal(8, 2)
  unitPrice         Decimal @db.Decimal(10, 2)
  vatCode           VatCode
  incomeAccount     String
}

model PaymentProviderSetting {
  id           String @id @default(cuid())
  activeProvider String @default("stripe")
  stripeSecret  String?
  stripeWebhookSecret String?
  gocardlessAccessToken String?
  metadata      Json?
  updatedAt     DateTime @updatedAt
}

model QuickBooksCredential {
  id           String   @id @default(cuid())
  realmId      String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// QuickBooks mapping tables removed - QB IDs now embedded directly on main models

model QuickBooksSyncSetting {
  id                String    @id @default(cuid())
  syncCustomers     Boolean   @default(true)
  syncInvoices      Boolean   @default(true)
  syncPayments      Boolean   @default(true)
  syncItems         Boolean   @default(true)
  autoSync          Boolean   @default(false)
  syncIntervalMins  Int       @default(30)
  // Delta sync high-water marks (LastUpdatedTime from QBO)
  lastCustomerSync  DateTime?
  lastItemSync      DateTime?
  lastInvoiceSync   DateTime?
  lastPaymentSync   DateTime?
  // When the sync was actually last executed
  lastSyncRanAt     DateTime?
  isSyncing         Boolean   @default(false)
  lastSyncStartedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SyncLog {
  id         String   @id @default(cuid())
  entity     String   // customer, item, invoice, payment
  direction  String   // qbo_to_app, app_to_qbo
  entityId   String?  // local entity ID
  qbId       String?  // QuickBooks entity ID
  action     String   // create, update, skip, error
  message    String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entity, createdAt])
  @@index([entityId])
}

model QuickBooksAccount {
  id                  String   @id @default(cuid())
  quickbooksId        String   @unique
  name                String
  fullyQualifiedName  String
  accountType         String
  accountSubType      String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GlobalSetting {
  id                String  @id @default(cuid())
  companyName       String  @default("Pilot Field Service Pro")
  companyNameSize   String  @default("text-xl")
  companyNameWeight String  @default("font-semibold")
  isVatRegistered   Boolean @default(true)
  defaultCurrency   String  @default("GBP")
  defaultNetTerms   Int     @default(14)
  quickbooksCompanyId String?
  // Appearance settings
  sidebarBg         String  @default("#ffffff")
  sidebarFont       String  @default("#475569")
  cardBg            String  @default("#ffffff")
  background        String  @default("#f8fafc")
  logo              String? // Base64 encoded image
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @map("refreshToken")
  access_token      String? @map("accessToken")
  expires_at        Int?    @map("expiresAt")
  token_type        String?
  scope             String?
  id_token          String? @map("idToken")
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
