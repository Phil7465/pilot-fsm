# Database
DATABASE_URL="postgresql://postgres.PROJECTREF:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECTREF:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me

# Encryption / Security
CRYPTO_SIGNING_KEY=replace-with-32-byte-hex

# Payment Providers
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_xxx
GOCARDLESS_ACCESS_TOKEN=sandbox_xxx

# QuickBooks Online
QBO_CLIENT_ID=your-client-id
QBO_CLIENT_SECRET=your-client-secret
QBO_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
QBO_ENVIRONMENT=sandbox

# Feature Flags
ENABLE_DEMO_DATA=true
